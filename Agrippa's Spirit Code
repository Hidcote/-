<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agrippa's Spirit Code V4.4.2 (Astrolabe OS Edit)</title>
    <!-- 引入 Astronomy Engine -->
    <script src="https://cdn.jsdelivr.net/npm/astronomy-engine@2.1.19/astronomy.browser.min.js"></script>
    <!-- 引入赛博魔导书质感字体 -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            /* 星空与赛博魔法配色体系 */
            --bg-color: #05070f; 
            --text-color: #c9d1d9; 
            --text-muted: #6e7681;
            --accent-cyan: #58a6ff; 
            --accent-glow: rgba(88, 166, 255, 0.4);
            --gold: #d2a83e; 
            --gold-glow: rgba(210, 168, 62, 0.4);
            --red: #ff7b72; 
            --red-glow: rgba(255, 123, 114, 0.4);
            --success: #238636;
            
            /* 毛玻璃卡片材质 */
            --glass-bg: rgba(13, 17, 23, 0.65);
            --glass-border: rgba(88, 166, 255, 0.15);
            --input-bg: rgba(1, 4, 9, 0.6);
        }

        body { 
            font-family: 'Consolas', 'Microsoft YaHei', monospace; 
            /* 虚数潜空间星空渐变背景 */
            background: radial-gradient(circle at 50% 0%, #151a2a 0%, var(--bg-color) 100%);
            background-attachment: fixed;
            color: var(--text-color); 
            margin: 0; 
            padding: 30px 15px; 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            min-height: 100vh;
        }

        h1 {
            font-family: 'Cinzel', serif;
            color: var(--gold);
            text-align: center;
            text-shadow: 0 0 15px var(--gold-glow);
            letter-spacing: 2px;
            margin-bottom: 30px;
        }

        h1 small {
            font-family: 'Consolas', monospace;
            display: block;
            font-size: 0.4em;
            letter-spacing: normal;
            color: var(--accent-cyan);
            text-shadow: none;
            margin-top: 5px;
            opacity: 0.8;
        }

        h2 {
            font-family: 'Cinzel', serif;
            color: #fff;
            border-bottom: 1px solid var(--glass-border);
            padding-bottom: 10px;
            margin-top: 0;
            font-size: 1.4em;
        }

        .container { 
            display: flex; 
            flex-wrap: wrap; 
            gap: 25px; 
            width: 100%; 
            max-width: 1100px; 
            justify-content: center; 
        }

        /* 毛玻璃面板样式 */
        .panel { 
            background: var(--glass-bg); 
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border); 
            padding: 25px; 
            border-radius: 12px; 
            flex: 1; 
            min-width: 320px; 
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .panel:hover {
            box-shadow: 0 8px 32px 0 rgba(88, 166, 255, 0.1);
        }
        
        /* Auto Calc Grid */
        .auto-calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px; }
        .full-width { grid-column: span 2; }
        
        /* 输入框赛博风格化 */
        .form-input, .coord-select, select, input[type="number"] { 
            background: var(--input-bg); 
            border: 1px solid rgba(255,255,255,0.1); 
            color: var(--accent-cyan); 
            padding: 10px; 
            border-radius: 6px; 
            box-sizing: border-box; 
            font-family: inherit;
            transition: all 0.3s ease;
            outline: none;
        }
        
        .form-input:focus, .coord-select:focus, select:focus, input[type="number"]:focus {
            border-color: var(--accent-cyan);
            box-shadow: 0 0 10px var(--accent-glow);
        }

        .form-input { width: 100%; }
        .form-label { font-size: 0.85em; color: #a5b2c0; margin-bottom: 6px; display: block; font-weight: bold; }
        .form-label span { font-weight: normal; font-size: 0.8em; opacity: 0.6; }

        .coord-group { display: flex; gap: 8px; }
        .coord-select { width: 85px; }
        
        /* 按钮光效魔法 */
        .btn-auto { 
            background: transparent; 
            color: var(--success); 
            border: 1px solid var(--success); 
            padding: 12px; 
            width: 100%; 
            cursor: pointer; 
            font-weight: bold; 
            border-radius: 6px; 
            transition: 0.3s; 
            font-family: 'Cinzel', serif; 
            font-size: 1.1em; 
            letter-spacing: 1px;
            box-shadow: inset 0 0 10px rgba(35, 134, 54, 0.1);
        }
        .btn-auto:hover:not(:disabled) { 
            background: rgba(35, 134, 54, 0.2);
            box-shadow: 0 0 15px rgba(35, 134, 54, 0.4), inset 0 0 10px rgba(35, 134, 54, 0.3);
            text-shadow: 0 0 8px rgba(35, 134, 54, 0.8);
        }
        .btn-auto:disabled { border-color: #333; color: #555; cursor: not-allowed; box-shadow: none; }

        .gen-btn { 
            width: 100%; 
            padding: 15px; 
            background: transparent; 
            color: var(--gold); 
            border: 1px solid var(--gold); 
            font-weight: bold; 
            margin-top: 25px; 
            border-radius: 6px;
            cursor: pointer; 
            font-family: 'Cinzel', serif; 
            font-size: 1.2em; 
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }
        .gen-btn:hover {
            background: rgba(210, 168, 62, 0.15);
            box-shadow: 0 0 20px var(--gold-glow), inset 0 0 15px var(--gold-glow);
            text-shadow: 0 0 8px var(--gold);
        }
        
        .quick-city { font-size: 0.75em; color: #8b949e; cursor: pointer; border-bottom: 1px dashed #8b949e; margin-right: 12px; transition: color 0.2s; }
        .quick-city:hover { color: var(--accent-cyan); border-bottom-color: var(--accent-cyan); }
        
        /* 防呆警告框 */
        .warning-box {
            margin-top: 20px; padding: 15px; 
            border: 1px solid rgba(255, 123, 114, 0.3); border-radius: 8px;
            background: rgba(255, 123, 114, 0.05); color: var(--red);
            font-size: 0.85em; line-height: 1.6;
            box-shadow: 0 0 15px var(--red-glow);
        }
        .warning-box strong { display: block; margin-bottom: 8px; font-size: 1.1em; font-family: 'Cinzel', serif; letter-spacing: 1px;}

        /* Manual Port Styles */
        .mode-switch { display: flex; background: rgba(0,0,0,0.3); margin: 20px 0; border: 1px solid var(--glass-border); border-radius: 6px; overflow: hidden;}
        .mode-btn { flex: 1; padding: 10px; text-align: center; cursor: pointer; font-size: 0.85em; color: var(--text-muted); transition: 0.3s;}
        .mode-btn.active { background: rgba(88, 166, 255, 0.2); color: var(--accent-cyan); font-weight: bold; box-shadow: inset 0 0 10px var(--accent-glow);}
        
        .input-group { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; border-bottom: 1px dashed rgba(255,255,255,0.05); padding: 8px 0; }
        .zodiac-container { display: flex; gap: 8px; }
        .input-sign { width: 110px; } .input-deg { width: 70px; } .input-abs { width: 90px; }
        .hidden { display: none !important; }

        /* Results Card */
        .result-card { 
            background: rgba(0,0,0,0.4); 
            border-left: 4px solid var(--accent-cyan); 
            border-radius: 4px 8px 8px 4px;
            padding: 20px; 
            margin-bottom: 15px; 
            position: relative;
            overflow: hidden;
        }
        .result-card::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(90deg, var(--accent-glow) 0%, transparent 100%);
            opacity: 0.1; pointer-events: none;
        }
        .result-card.evil { border-left-color: var(--red); }
        .result-card.evil::before { background: linear-gradient(90deg, var(--red-glow) 0%, transparent 100%); }
        
        .hebrew-name { font-size: 2.8em; color: var(--gold); font-family: 'Cinzel', serif; direction: rtl; text-shadow: 0 0 15px var(--gold-glow); margin: 10px 0;}
        .latin-name { font-weight: bold; letter-spacing: 3px; font-size: 1.1em; color: #fff;}
        
        /* Tabs */
        .tabs { display: flex; gap: 8px; margin-bottom: 20px; }
        .tab { flex: 1; text-align: center; padding: 10px; background: rgba(0,0,0,0.3); cursor: pointer; font-size: 0.85em; color: var(--text-muted); border-radius: 6px; border: 1px solid transparent; transition: 0.3s;}
        .tab.active { background: rgba(88, 166, 255, 0.1); color: var(--accent-cyan); border-color: var(--glass-border); font-weight: bold; box-shadow: 0 0 10px var(--accent-glow);}
        
        /* SVG Magic Circle */
        #svg-container { text-align: center; margin-top: 30px; }
        svg { filter: drop-shadow(0 0 10px rgba(88, 166, 255, 0.2)); }
    </style>
</head>
<body>

    <h1>Agrippa's Spirit Code <small>阿格里帕灵体生成器 V4.4.3</small></h1>

    <div class="container">
        <!-- Panel 1: Calculator / Inputs -->
        <div class="panel">
            <h2>0. 自动排盘 <span style="font-size:0.5em; font-family: 'Consolas'; float:right; margin-top:8px; color:var(--text-muted)">Auto Calculation</span></h2>
            <div style="margin-bottom:15px;">
                <span class="quick-city" onclick="fillCity(39.9042, 116.4074, 8)">北京 (Beijing)</span>
                <span class="quick-city" onclick="fillCity(31.2304, 121.4737, 8)">上海 (Shanghai)</span>
                <span class="quick-city" onclick="fillCity(51.5074, -0.1278, 0)">伦敦 (London)</span>
                <span class="quick-city" onclick="fillCity(40.7128, -74.0060, -5)">纽约 (New York)</span>
            </div>
            
            <div class="auto-calc-grid">
                <div>
                    <label class="form-label">日期 <span>Date</span></label>
                    <input type="date" id="auto-date" class="form-input">
                </div>
                <div>
                    <label class="form-label">时间 <span>Time</span></label>
